<?xml version="1.0"?>
<robot name="stair_skeleton">
    <link name="world" />
    <link name="stair_link">
        <inertial>
            <mass value="100.0" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="10.0" ixy="0" ixz="0" iyy="10.0" iyz="0" izz="10.0" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="brown"><color rgba="0.6 0.4 0.2 1"/></material>
            <geometry>
                <box size="4.0 2.0 0.1" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="4.0 2.0 0.1" />
            </geometry>
        </collision>
    </link>
    <joint name="stair_joint" type="fixed">
        <origin xyz="2.9 0 0.05" rpy="0 0 0" />
        <parent link="world" />
        <child link="stair_link" />
    </joint>
</robot>
